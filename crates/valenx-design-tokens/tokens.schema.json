{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://valenx.org/schemas/design-tokens/0.1.0",
  "title": "Valenx Design Tokens",
  "description": "Canonical design-token schema. See RFC 0006.",
  "type": "object",
  "required": ["version", "color", "type", "space", "radius", "border", "z", "motion"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },

    "color": {
      "type": "object",
      "required": ["surface", "text", "accent", "physics"],
      "additionalProperties": false,
      "properties": {
        "surface":       { "type": "object", "patternProperties": { "^[0-5]$": { "$ref": "#/definitions/hex" } }, "additionalProperties": false },
        "text":          { "type": "object", "patternProperties": { "^[1-3]$": { "$ref": "#/definitions/hex" } }, "additionalProperties": false },
        "accent":        { "type": "object", "required": ["primary", "success", "warning", "error", "info"], "additionalProperties": { "$ref": "#/definitions/hex" } },
        "physics":       { "type": "object", "required": ["cfd", "fea", "em", "chem", "md", "battery"], "additionalProperties": { "$ref": "#/definitions/hex" } },
        "light_surface": { "type": "object", "patternProperties": { "^[0-5]$": { "$ref": "#/definitions/hex" } }, "additionalProperties": false },
        "light_text":    { "type": "object", "patternProperties": { "^[1-3]$": { "$ref": "#/definitions/hex" } }, "additionalProperties": false },
        "hc_surface":    { "type": "object", "patternProperties": { "^[0-5]$": { "$ref": "#/definitions/hex" } }, "additionalProperties": false },
        "hc_text":       { "type": "object", "patternProperties": { "^[1-3]$": { "$ref": "#/definitions/hex" } }, "additionalProperties": false },
        "hc_accent":     { "type": "object", "additionalProperties": { "$ref": "#/definitions/hex" } }
      }
    },

    "type": {
      "type": "object",
      "required": ["family", "size", "weight", "lineHeight"],
      "additionalProperties": false,
      "properties": {
        "family":     { "type": "object", "required": ["ui", "mono"], "additionalProperties": { "type": "string" } },
        "size":       { "type": "object", "additionalProperties": { "type": "number", "minimum": 6, "maximum": 72 } },
        "weight":     { "type": "object", "additionalProperties": { "type": "integer", "minimum": 100, "maximum": 900 } },
        "lineHeight": { "type": "object", "additionalProperties": { "type": "number", "minimum": 1, "maximum": 3 } }
      }
    },

    "space":  { "type": "object", "additionalProperties": { "type": "number", "minimum": 0, "maximum": 512 } },
    "radius": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0 } },
    "border": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0 } },
    "z":      { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },

    "motion": {
      "type": "object",
      "required": ["duration_ms", "easing"],
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 2000 } },
        "easing":      { "type": "object", "additionalProperties": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "number", "minimum": 0, "maximum": 1 } } }
      }
    },

    "themes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["overrides"],
        "properties": {
          "extends":   { "type": ["string", "null"] },
          "overrides": { "type": "object" }
        }
      }
    }
  },

  "definitions": {
    "hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
  }
}

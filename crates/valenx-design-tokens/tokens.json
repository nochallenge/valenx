{
  "$schema": "./tokens.schema.json",
  "version": "0.1.0",

  "color": {
    "surface": {
      "0": "#0E1116",
      "1": "#161A22",
      "2": "#1D232C",
      "3": "#252C37",
      "4": "#2E3642",
      "5": "#38414F"
    },
    "text": {
      "1": "#E6EBF1",
      "2": "#A8B2BF",
      "3": "#6B7482"
    },
    "accent": {
      "primary": "#4B9EFF",
      "success": "#3FC27A",
      "warning": "#E0A43D",
      "error":   "#E55B5B",
      "info":    "#4B9EFF"
    },
    "physics": {
      "cfd":     "#4B9EFF",
      "fea":     "#E0A43D",
      "em":      "#9D7DF0",
      "chem":    "#3FC27A",
      "md":      "#E55B5B",
      "battery": "#F07DA6"
    },
    "light_surface": {
      "0": "#FFFFFF",
      "1": "#F7F8FA",
      "2": "#EEF1F4",
      "3": "#E2E7EE",
      "4": "#CFD6DF",
      "5": "#B3BCC7"
    },
    "light_text": {
      "1": "#0E1116",
      "2": "#3A424E",
      "3": "#5B6371"
    },
    "hc_surface": {
      "0": "#000000",
      "1": "#000000",
      "2": "#0A0A0A",
      "3": "#141414",
      "4": "#1E1E1E",
      "5": "#2A2A2A"
    },
    "hc_text": {
      "1": "#FFFFFF",
      "2": "#FFFFFF",
      "3": "#E6E6E6"
    },
    "hc_accent": {
      "primary": "#FFD400",
      "success": "#00FF66",
      "warning": "#FFA000",
      "error":   "#FF5252",
      "info":    "#62D7FF"
    }
  },

  "type": {
    "family": {
      "ui":   "Inter",
      "mono": "JetBrains Mono"
    },
    "size": {
      "xs":   11,
      "sm":   12,
      "base": 14,
      "lg":   16,
      "xl":   18,
      "2xl":  24,
      "3xl":  32
    },
    "weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600
    },
    "lineHeight": {
      "tight":  1.2,
      "normal": 1.45,
      "loose":  1.6
    }
  },

  "space":  { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "7": 32, "8": 40, "9": 48, "10": 64, "11": 80, "12": 96 },
  "radius": { "none": 0, "sm": 2, "md": 6, "lg": 10, "full": 9999 },
  "border": { "hairline": 0.5, "default": 1, "strong": 2 },
  "z":      { "base": 0, "docked": 10, "overlay": 100, "modal": 1000, "tooltip": 2000 },

  "motion": {
    "duration_ms": { "fast": 120, "base": 180, "slow": 300, "camera": 400 },
    "easing":      { "standard": [0.4, 0.0, 0.2, 1.0], "decelerate": [0.0, 0.0, 0.2, 1.0], "emphasized": [0.2, 0.0, 0.0, 1.0] }
  }
}

# EditorConfig — https://editorconfig.org
#
# Keeps editors consistent across contributors, OSes, and tools (VS
# Code, JetBrains, Vim, etc.). Complements rustfmt.toml for
# non-Rust files (TOML, Markdown, YAML, shell, etc.).

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{rs,toml}]
indent_size = 4

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
indent_size = 2
# Trailing whitespace in Markdown is sometimes meaningful (two spaces
# = <br>), so leave it alone.
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2
end_of_line = lf

[Makefile]
indent_style = tab

# Windows batch / PowerShell: CRLF to match platform tooling
[*.{bat,cmd,ps1,psm1}]
end_of_line = crlf
